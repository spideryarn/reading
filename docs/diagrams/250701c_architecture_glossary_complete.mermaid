graph TB
    %% User Interface Layer
    subgraph "Frontend - User Interface"
        Start([User clicks<br/>Load Glossary])
        GlossaryPanel[📖 Glossary Panel]
        SearchBox[🔍 Search Box]
        LoadMoreBtn[Load More button]
        EntityList[Entity List Display:<br/>Name + Ontology badge<br/>Long explanation]
        DocumentView[Document Viewer]
    end
    
    %% API & Validation Layer
    subgraph "API Layer - /api/tools/glossary"
        APIEndpoint[POST /api/tools/glossary]
        AuthCheck[🔐 requireAuth middleware]
        ZodValidation[✅ Zod schema validation]
        ToolExecutor[Tool Executor Framework]
    end
    
    %% Core Processing Layer
    subgraph "Business Logic"
        CheckCache{Cached<br/>entities<br/>exist?}
        EnhancementService[Enhancement Service]
        IndividualEntityStorage[Individual Entity Storage]
        PositionTracking[📍 Position Tracking:<br/>First occurrence<br/>Sort by position]
        ScoringEngine[🎯 Scoring Engine:<br/>Difficulty 0-1<br/>Centrality 0-1]
    end
    
    %% LLM Processing Layer
    subgraph "LLM Processing"
        PreparePrompt[Prepare Prompt:<br/>HTML content<br/>Entity cap = 20<br/>Skip count for pagination]
        NunjucksTemplate[📝 glossary.njk template]
        LLMCall[🤖 LLM generateObject:<br/>Claude/Gemini provider]
        ResponseParsing[Parse & Validate:<br/>Entity schema<br/>Ontology types]
    end
    
    %% Document Integration Layer
    subgraph "Document Highlighting"
        MarkJS[🎨 Mark.js highlighting:<br/>Orange underline<br/>Book emoji 📖]
        TooltipSystem[💬 Tooltip system:<br/>Hover/long-press<br/>Markdown rendering]
        CrossPaneComm[🔄 Cross-pane messaging]
        URLStateSync[🔗 URL state:<br/>?tab=glossary&term=X]
    end
    
    %% Error & Safety Layer
    subgraph "Error Handling & Safety"
        TimeoutMitigation[⏱️ Timeout mitigation:<br/>504 prevention<br/>20 entity cap]
        ErrorHandling[❌ Error states:<br/>Clear messages<br/>Phosphor icons]
        ProgressiveLoading[Progressive loading:<br/>more_entities flag]
    end
    
    %% Main Flow
    Start --> GlossaryPanel
    GlossaryPanel --> APIEndpoint
    APIEndpoint --> AuthCheck
    AuthCheck --> ZodValidation
    ZodValidation --> ToolExecutor
    ToolExecutor --> CheckCache
    
    %% Cache Hit Path
    CheckCache -->|Yes| IndividualEntityStorage
    IndividualEntityStorage -->|Load entities| PositionTracking
    
    %% Cache Miss Path  
    CheckCache -->|No| PreparePrompt
    PreparePrompt --> NunjucksTemplate
    NunjucksTemplate --> LLMCall
    LLMCall --> ResponseParsing
    
    %% Error Path
    LLMCall -->|Timeout| TimeoutMitigation
    ResponseParsing -->|Invalid| ErrorHandling
    TimeoutMitigation --> ErrorHandling
    ErrorHandling --> GlossaryPanel
    
    %% Success Path
    ResponseParsing -->|Valid| EnhancementService
    EnhancementService --> IndividualEntityStorage
    IndividualEntityStorage -->|Save entities| PositionTracking
    
    %% Entity Processing
    PositionTracking --> ScoringEngine
    ScoringEngine --> EntityList
    
    %% UI Display
    EntityList --> GlossaryPanel
    EntityList -->|More available| LoadMoreBtn
    LoadMoreBtn -->|Click| PreparePrompt
    
    %% Document Integration
    EntityList -->|Display| MarkJS
    MarkJS --> DocumentView
    DocumentView -->|Hover/tap| TooltipSystem
    EntityList -->|Click entity| CrossPaneComm
    CrossPaneComm --> URLStateSync
    CrossPaneComm -->|Scroll to| DocumentView
    
    %% Search Flow
    SearchBox -->|Filter| EntityList
    
    %% Progressive Loading
    ResponseParsing -->|more_entities=true| ProgressiveLoading
    ProgressiveLoading --> LoadMoreBtn
    
    %% Styling
    style Start fill:#e8f4f8
    style LLMCall fill:#fff4e6
    style IndividualEntityStorage fill:#f0f9ff
    style ErrorHandling fill:#fee2e2
    style MarkJS fill:#fef3c7
    style URLStateSync fill:#e0f7fa
    
    %% Class Definitions
    classDef frontend fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef api fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    classDef business fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    classDef llm fill:#fff9c4,stroke:#f9a825,stroke-width:2px
    classDef error fill:#ffebee,stroke:#c62828,stroke-width:2px
    
    class Start,GlossaryPanel,SearchBox,LoadMoreBtn,EntityList,DocumentView frontend
    class APIEndpoint,AuthCheck,ZodValidation,ToolExecutor api
    class CheckCache,EnhancementService,IndividualEntityStorage,PositionTracking,ScoringEngine business
    class PreparePrompt,NunjucksTemplate,LLMCall,ResponseParsing llm
    class TimeoutMitigation,ErrorHandling,ProgressiveLoading error