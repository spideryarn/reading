# Core configuration
PORT=3000

# Database (Supabase)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# AI/LLM Configuration
# LLM Model to use (defaults to claude-sonnet-4-20250514 if not set)
# For development, use claude-3-haiku-20240307 for faster/cheaper responses
LLM_MODEL=claude-3-haiku-20240307

# LLM Provider selection (anthropic | google)
# Defaults to anthropic if not set
LLM_PROVIDER=anthropic

# Anthropic API key (required for Claude models)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Generative AI API key (required for Gemini models)
# Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key

# Model mapping for providers
# When LLM_PROVIDER=google, LLM_MODEL should be a Gemini model like:
# - gemini-1.5-flash (fast, cheap)
# - gemini-1.5-pro (more capable)
# - gemini-1.5-pro-latest (latest version)