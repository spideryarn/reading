# Dev webserver configuration, different for each Git worktree folder.
PORT=3000

# Database (Supabase)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# AI/LLM Configuration
# Model string format: provider:model:version[:thinking]
# Use cheaper models for development (fast and cost-effective)
# For production, consider more capable models
# See docs/reference/LLM_MODEL_CONFIGURATION.md for complete model comparison
LLM_MODEL=google:gemini-2.0-flash:latest        # Fast & cheap (default - for dev)
# LLM_MODEL=anthropic:claude-3-5-haiku:20241022  # Fast & cheap alternative
# LLM_MODEL=anthropic:claude-sonnet-4:20250514   # Balanced (for production)
# LLM_MODEL=google:gemini-2.5-pro:latest         # High-end option

# Anthropic API key (required for anthropic:* models)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Generative AI API key (required for google:* models)
# Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key

# Stripe Configuration
# Get your keys from: https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Product Configuration
STRIPE_PRICE_ID=price_... # Monthly subscription price ID