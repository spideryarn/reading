# ⚠️  WARNING: This file should NEVER be committed to Git!
# - If you see this file in Git status, DO NOT commit it. Add it to .gitignore instead, stop, and alert the user.
# - If you notice that this file has already been stored in Git, stop immediately and alert the user.

# Core configuration
PORT=3000

# Database (Supabase)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# AI/LLM Configuration
# Provider-tier model selection using {provider}-{tier} format
# Defaults to google-cheap for development (fast and cost-effective)
# For production, consider anthropic-balanced or google-expensive
# See docs/LLM_MODELS_REFERENCE.md for complete model comparison
# LLM_MODEL=anthropic-balanced # Use Claude Sonnet 4 (for prod probably)
LLM_MODEL=google-cheap       # Use Gemini 2.5 Flash (default - for dev)
# Available provider-tier keys:
# Development (fast/cheap): google-cheap, anthropic-cheap  
# Production (balanced): anthropic-balanced, google-balanced
# High-end (expensive): anthropic-expensive, google-expensive

# Anthropic API key (required for anthropic-* models)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Generative AI API key (required for google-* models)
# Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key

# Stripe Configuration
# Get your keys from: https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Product Configuration
STRIPE_PRICE_ID=price_... # Monthly subscription price ID